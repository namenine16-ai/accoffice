generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id                 Int       @id @default(autoincrement())

  code               String    @unique
  companyName        String
  taxId              String    @unique

  businessType       String?
  companyRegisterNo  String?
  vatRegistered      Boolean   @default(false)
  vatNumber          String?

  address            String?
  province           String?
  postcode           String?

  contactName        String?
  phone              String?
  email              String?
  lineId             String?

  accountant         String?

  serviceType        String?
  accountingPeriod   String?

  serviceFee         Float?    @default(0)

  startDate          DateTime?

  status             String    @default("ใช้งาน")

  note               String?

  googleDriveFolder  String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
