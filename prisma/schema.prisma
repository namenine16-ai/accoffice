generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id                Int       @id @default(autoincrement())
  code              String    @unique
  companyName       String
  taxId             String    @unique
  businessType      String?
  companyRegisterNo String?
  vatRegistered     Boolean   @default(false)
  vatNumber         String?
  address           String?
  province          String?
  postcode          String?
  contactName       String?
  phone             String?
  email             String?
  lineId            String?
  accountant        String?
  serviceType       String?
  accountingPeriod  String?
  serviceFee        Float     @default(0)
  startDate         DateTime?
  status            String    @default("ใช้งาน")
  note              String?
  googleDriveFolder String?

  tasks     CustomerTask[]
  documents Document[]
  taxTasks  TaxTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerTask {
  id                 Int  @id @default(autoincrement())
  customerId         Int
  assignedEmployeeId Int?

  month Int
  year  Int

  status      String    @default("pending")
  progress    Int       @default(0)
  deadline    DateTime?
  completedAt DateTime?
  priority    String    @default("normal")
  remarks     String?

  receiveDoc Boolean @default(false)
  vat        Boolean @default(false)
  pnd1       Boolean @default(false)
  pnd3       Boolean @default(false)
  pnd53      Boolean @default(false)
  sso        Boolean @default(false)
  closing    Boolean @default(false)

  note String?

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  documents Document[]
  taxTasks  TaxTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                Int             @id @default(autoincrement())
  email             String          @unique
  password          String
  name              String?
  isActive          Boolean         @default(true)
  employee          Employee?       @relation("UserEmployee")
  roles             Role[]
  activityLogs      ActivityLog[]
  uploadedDocuments Document[]
  deletedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  taxSubmissions    TaxSubmission[]
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[]
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  roles       Role[]
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Employee {
  id            Int            @id @default(autoincrement())
  user          User?          @relation("UserEmployee", fields: [userId], references: [id], onDelete: SetNull)
  userId        Int?           @unique
  firstName     String
  lastName      String
  email         String         @unique
  phone         String?
  position      String?
  department    String?
  status        String         @default("active")
  deletedAt     DateTime?
  activityLogs  ActivityLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  customerTasks CustomerTask[]
  taxTasks      TaxTask[]
}

model ActivityLog {
  id         Int       @id @default(autoincrement())
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int?
  action     String
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee? @relation(fields: [employeeId], references: [id])
  employeeId Int?
}

enum DocumentCategory {
  ACCOUNTING
  TAX
  VAT
  PAYROLL
  SOCIAL_SECURITY
  FINANCIAL
  CONTRACT
  LICENSE
  RECEIPT
  INVOICE
  BANK
  ASSET
  LEGAL
  HR
  OTHER
  ARCHIVE
}

model Document {
  id           Int           @id @default(autoincrement())
  customerId   Int
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  taskId       Int?
  task         CustomerTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  uploadedById Int?
  uploadedBy   User?         @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  fileName    String
  storedName  String
  filePath    String
  extension   String
  mimeType    String
  fileSize    Int
  checksum    String
  version     Int              @default(1)
  category    DocumentCategory
  subCategory String?
  note        String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaxTaskStatus {
  PENDING
  READY
  IN_PROGRESS
  WAITING_DOCUMENTS
  FILED
  COMPLETED
  CANCELLED
}

enum TaxSubmissionStatus {
  SUBMITTED
  ACCEPTED
  REJECTED
}

model TaxType {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  name        String
  description String?
  isActive    Boolean @default(true)

  dueDateRule DueDateRule?
  taxTasks    TaxTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DueDateRule {
  id        Int     @id @default(autoincrement())
  taxTypeId Int     @unique
  taxType   TaxType @relation(fields: [taxTypeId], references: [id], onDelete: Cascade)

  dayOfMonth             Int
  monthOffset            Int     @default(1)
  allowWeekendAdjustment Boolean @default(true)
  allowHolidayAdjustment Boolean @default(true)
  notes                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaxTask {
  id                 Int          @id @default(autoincrement())
  customerId         Int
  customer           Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerTaskId     Int
  customerTask       CustomerTask @relation(fields: [customerTaskId], references: [id], onDelete: Cascade)
  taxTypeId          Int
  taxType            TaxType      @relation(fields: [taxTypeId], references: [id], onDelete: Restrict)
  assignedEmployeeId Int?
  employee           Employee?    @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  month       Int
  year        Int
  dueDate     DateTime
  status      TaxTaskStatus @default(PENDING)
  priority    Priority      @default(NORMAL)
  remarks     String?
  completedAt DateTime?

  submissions TaxSubmission[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([customerId, year, month])
  @@index([assignedEmployeeId])
  @@index([deletedAt])
  @@index([status, dueDate])
}

model TaxSubmission {
  id            Int     @id @default(autoincrement())
  taxTaskId     Int
  taxTask       TaxTask @relation(fields: [taxTaskId], references: [id], onDelete: Cascade)
  submittedById Int?
  submittedBy   User?   @relation(fields: [submittedById], references: [id], onDelete: SetNull)

  submittedAt     DateTime            @default(now())
  receivedDate    DateTime?
  referenceNumber String?
  amount          Float?
  status          TaxSubmissionStatus @default(SUBMITTED)
  rejectedReason  String?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
